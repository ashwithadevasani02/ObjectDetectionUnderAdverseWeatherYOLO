# Copy this file to .env and adjust variables as needed
PORT=4000
PYTHON_PATH=python

# --- Memory tuning (recommended on small/constrained hosts, e.g. Render free tier) ---
# The backend already applies these defaults to the Python child process, but you
# can override them here. MALLOC_ARENA_MAX is the biggest lever for cutting the
# PyTorch/YOLO resident memory that causes OOM crash-loops on 512MB instances.
# MALLOC_ARENA_MAX=2
# OMP_NUM_THREADS=1
# OPENBLAS_NUM_THREADS=1
# MKL_NUM_THREADS=1
# NUMEXPR_NUM_THREADS=1
# VECLIB_MAXIMUM_THREADS=1
# MPLBACKEND=Agg
