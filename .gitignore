# Node Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment configurations (secret keys & local configurations)
.env
backend/.env
backend/.env.local

# Compile/Build directories
frontend/dist/

# Runtime caches (matplotlib font cache, etc.)
backend/.cache/

# Python bytecode
__pycache__/
*.pyc

# OS specific files
.DS_Store
Thumbs.db
desktop.ini

# Machine Learning Binaries & Models
*.pth
*.onnx

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Uploads (ignore uploaded images but track directory via .gitkeep)
backend/uploads/*
!backend/uploads/.gitkeep
